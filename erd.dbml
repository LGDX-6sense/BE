// Use DBML to define your database structure
// Docs: https://dbml.dbdiagram.io/docs

Table users {
  id integer [primary key]
  name varchar
  phone varchar
  created_at timestamp
}

Table user_products {
  id integer [primary key]
  user_id integer [not null]
  category varchar [note: '냉장고, 세탁기 등']
  model_name varchar
  is_registered boolean [note: '앱 등록 기기 여부 (등록/미등록 구분)']
}

Table as_requests {
  id integer [primary key]
  user_product_id integer [not null, unique, note: '제품 1개당 요청 1개']
  status varchar [note: '진단중, 가이드제공, 해결됨, 예약됨']
  created_at timestamp
}

Table symptoms {
  id integer [primary key]
  as_request_id integer [not null]
  type varchar [note: 'TEXT, IMAGE, VOICE']
  content text [note: '텍스트 내용 또는 사진/녹음 URL']
  created_at timestamp
}

Table ai_diagnoses {
  id integer [primary key]
  as_request_id integer [not null, unique, note: '요청당 AI 진단 0 또는 1건']
  symptom_type varchar [note: 'Step 1: 분류된 증상']
  inferred_cause varchar [note: 'Step 2: 추론된 원인']
  severity varchar [note: 'Step 3: SELF, EXPERT, MORE_INFO']
  summary text [note: '상담사 전달용 AI 요약본']
}

Table diagnosis_logs {
  id integer [primary key]
  diagnosis_id integer [not null]
  question text [note: '추가 정보 필요 시 AI 질문']
  answer text [note: '사용자 답변']
  created_at timestamp
}

Table guides {
  id integer [primary key]
  category varchar [note: '제품 카테고리']
  title varchar [note: '자가해결 가이드 제목']
  content_url text [note: '가이드 상세 내용 및 영상 링크']
}

Table reservations {
  id integer [primary key]
  as_request_id integer [not null, unique, note: '요청당 예약 0 또는 1개']
  type varchar [note: 'CALL(전화상담), VISIT(출장수리)']
  schedule_date timestamp
  agent_info varchar [note: '배정된 상담사 또는 기사 정보']
  created_at timestamp
}

Table reviews {
  id integer [primary key]
  as_request_id integer [not null, unique, note: '요청당 리뷰 0 또는 1개']
  is_solved boolean [note: '자가해결 성공 여부']
  score integer [note: '만족도 별점 (1~5)']
  created_at timestamp
}

// Relationships
Ref: user_products.user_id > users.id
Ref: as_requests.user_product_id - user_products.id
Ref: symptoms.as_request_id > as_requests.id
Ref: ai_diagnoses.as_request_id - as_requests.id
Ref: diagnosis_logs.diagnosis_id - ai_diagnoses.id
Ref: reservations.as_request_id - as_requests.id
Ref: reviews.as_request_id - as_requests.id

