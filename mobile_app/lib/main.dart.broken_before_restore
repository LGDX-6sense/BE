  Future<void> _pickAudio() async {
    final result = await FilePicker.platform.pickFiles(
      allowMultiple: false,
      type: FileType.audio,
    );

    if (!mounted || result == null || result.files.isEmpty) {
      return;
    }

    final picked = result.files.single;
    if (picked.path == null) {
      setState(() {
        _errorMessage = '?좏깮???ㅻ뵒???뚯씪???쎌쓣 ???놁뒿?덈떎.';
      });
      return;
    }

    final extension = picked.extension?.toLowerCase() ?? '';
    if (!_supportedAudioExtensions.contains(extension)) {
      setState(() {
        _errorMessage = '吏?먰븯???ㅻ뵒???뺤떇留??ъ슜?????덉뼱?? wav, mp3, m4a, aac, flac';
      });
      return;
    }

    setState(() {
      _selectedAudio = File(picked.path!);
      _selectedAudioName = picked.name;
      _errorMessage = null;
    });
  }

  Future<void> _toggleVoiceRecording() async {
    if (_isRecordingVoice) {
      await _stopVoiceRecording();
      return;
    }
    await _startVoiceRecording();
  }

  Future<void> _startVoiceRecording() async {
    if (_isSubmitting) {
      return;
    }

    try {
      await _stopSpeaking();
      final hasPermission = await _voiceRecorder.hasPermission();
      if (!hasPermission) {
        if (!mounted) {
          return;
        }
        setState(() {
          _errorMessage = '留덉씠??沅뚰븳???꾩슂?⑸땲??';
        });
        return;
      }

      final tempDir = await getTemporaryDirectory();
      final timestamp = DateTime.now().millisecondsSinceEpoch;
      final outputPath =
          '${tempDir.path}${Platform.pathSeparator}recorded_audio_$timestamp.m4a';

      await _voiceRecorder.start(
